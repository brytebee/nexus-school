{
  "name": "nexusschoolos",
  "productName": "Nexus School OS",
  "version": "1.0.1",
  "description": "High-End School Management System — Desktop Shell",
  "author": "Nexus Infrastructure",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/brytebee/nexus-school.git"
  },
  "main": "main.js",
  "scripts": {
    "start": "electron .",
    "build": "vite build",
    "test": "vitest run",
    "test:e2e": "playwright test",
    "test:e2e:report": "playwright show-report test-results/html-report",
    "videos:transcode": "node scripts/transcode-videos.js",
    "test:all": "npm run test && npm run test:e2e",
    "predist:mac": "npm run build && npm run test",
    "predist:win": "npm run build && npm run test",
    "predist:linux": "npm run build && npm run test",
    "predist:all": "npm run build && npm run test",
    "prepublish:mac": "npm run build && npm run test",
    "prepublish:win": "npm run build && npm run test",
    "dist:mac": "electron-builder --mac",
    "dist:win": "electron-builder --win",
    "dist:linux": "electron-builder --linux",
    "dist:all": "electron-builder --mac --win --linux",
    "publish:mac": "electron-builder --mac --publish always",
    "publish:win": "electron-builder --win --publish always",
    "publish:linux": "electron-builder --linux --publish always"
  },
  "build": {
    "appId": "ng.nexusos.schoolos",
    "productName": "Nexus School OS",
    "copyright": "Copyright © 2026 Nexus Infrastructure Ltd.",
    "npmRebuild": true,
    "asar": true,
    "asarUnpack": [
      "node_modules/better-sqlite3/**",
      "node_modules/whatsapp-web.js/**",
      "node_modules/puppeteer/**",
      "node_modules/puppeteer-core/**"
    ],
    "directories": {
      "output": "release"
    },
    "publish": [
      {
        "provider": "github",
        "owner": "brytebee",
        "repo": "nexus-school-releases",
        "private": false,
        "releaseType": "release"
      }
    ],
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "arm64",
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.icns",
      "category": "public.app-category.education"
    },
    "win": {
      "target": [
        {
          "target": "nsis",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.ico"
    },
    "linux": {
      "target": [
        {
          "target": "AppImage",
          "arch": [
            "x64"
          ]
        },
        {
          "target": "deb",
          "arch": [
            "x64"
          ]
        }
      ],
      "icon": "assets/icon.png",
      "category": "Education",
      "maintainer": "Nexus Infrastructure Ltd <support@nexusos.com.ng>",
      "synopsis": "High-End School Management System"
    },
    "deb": {
      "depends": [
        "libglib2.0-0",
        "libnss3",
        "libatk1.0-0",
        "libatk-bridge2.0-0",
        "libgtk-3-0",
        "libgbm1",
        "libasound2"
      ]
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true,
      "createDesktopShortcut": true,
      "runAfterFinish": true
    },
    "files": [
      "**/*",
      "!.env",
      "!.env.local",
      "!release/**",
      "!private_engine/**",
      "!node_modules/whatsapp-web.js/.wwebjs_cache/**",
      "!node_modules/whatsapp-web.js/.wwebjs_auth/**",
      "!**/*.map",
      "!**/*.ts",
      "!nexus-engine-*.tgz",
      "!nexus_school_electron_backup.zip",
      "!*.sqlite",
      "!*.sqlite-shm",
      "!*.sqlite-wal",
      "!*.sqlite.seed_backup",
      "!tests/**",
      "!playwright.config.js",
      "!tsconfig*.json",
      "!vite.config.ts",
      "!verify-*.js",
      "!patch_*.js",
      "!run_init.js",
      "!errors.txt",
      "!Sample_*.csv"
    ],
    "extraResources": [
      {
        "from": "assets/",
        "to": "assets/",
        "filter": [
          "**/*"
        ]
      }
    ]
  },
  "dependencies": {
    "@nexus/engine": "file:../../private_engine",
    "address": "^1.2.2",
    "better-sqlite3": "^11.10.0",
    "bonjour-service": "^1.3.0",
    "csv-parser": "^3.2.0",
    "dotenv": "^17.4.2",
    "express": "^4.18.2",
    "googleapis": "^171.4.0",
    "handlebars": "^4.7.9",
    "lucide-react": "^1.16.0",
    "mammoth": "^1.12.0",
    "nodemailer": "^6.10.1",
    "pdf-parse": "^2.4.5",
    "pdfkit": "^0.19.1",
    "qrcode": "^1.5.4",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "speakeasy": "^2.0.0",
    "whatsapp-web.js": "^1.34.7"
  },
  "devDependencies": {
    "@playwright/test": "^1.60.0",
    "@tailwindcss/vite": "^4.3.0",
    "@types/node": "^20",
    "@vitejs/plugin-react": "^6.0.2",
    "electron": "^31.0.0",
    "electron-builder": "25.1.8",
    "electron-rebuild": "^3.2.9",
    "electron-updater": "6.8.3",
    "vite": "^8.0.14",
    "vitest": "^4.1.7"
  }
}
