<?xml version="1.0" encoding="utf-8"?>
<manifest xmlns:android="http://schemas.android.com/apk/res/android">

    <uses-permission android:name="android.permission.INTERNET" />
    <uses-permission android:name="android.permission.CAMERA" />
    <!-- Required to create camera temp files on API ≤ 28 -->
    <uses-permission
        android:name="android.permission.WRITE_EXTERNAL_STORAGE"
        android:maxSdkVersion="28" />
    <!-- Gallery photo pick: API 33+ uses READ_MEDIA_IMAGES; older APIs use READ_EXTERNAL_STORAGE -->
    <uses-permission
        android:name="android.permission.READ_MEDIA_IMAGES"
        android:minSdkVersion="33" />
    <uses-permission
        android:name="android.permission.READ_EXTERNAL_STORAGE"
        android:maxSdkVersion="32" />

    <application
        android:name=".NexusApp"
        android:allowBackup="true"
        android:icon="@drawable/ic_nexus_logo"
        android:label="@string/app_name"
        android:supportsRtl="true"
        android:theme="@style/Theme.Nexus">
        <activity
            android:name=".ui.MainActivity"
            android:exported="true">
            <intent-filter>
                <action android:name="android.intent.action.MAIN" />
                <category android:name="android.intent.category.LAUNCHER" />
            </intent-filter>
        </activity>
        <activity android:name=".ui.LockActivity" />
        <activity android:name=".ui.HandshakeActivity" />
        <activity android:name=".ui.StudentRosterActivity" />
        <activity android:name=".ui.AppLaunchActivity" />
        <!-- DemoResetActivity retained for historical reference — no longer routed to -->
        <activity android:name=".ui.DemoResetActivity" />

        <!-- Gold Phase B: Daily Attendance Register -->
        <activity
            android:name=".ui.AttendanceActivity"
            android:windowSoftInputMode="adjustResize" />

        <!-- Role Based Activities -->
        <activity android:name=".ui.ResultClerkActivity" />
        <activity android:name=".ui.BursarActivity" />
        <activity android:name=".ui.ItAdminActivity" />
        <activity android:name=".ui.PrincipalActivity" />

        <!-- FileProvider for camera capture intents (API 24+) -->
        <provider
            android:name="androidx.core.content.FileProvider"
            android:authorities="${applicationId}.fileprovider"
            android:exported="false"
            android:grantUriPermissions="true">
            <meta-data
                android:name="android.support.FILE_PROVIDER_PATHS"
                android:resource="@xml/file_paths" />
        </provider>
    </application>

</manifest>

